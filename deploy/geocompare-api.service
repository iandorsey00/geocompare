[Unit]
Description=GeoCompare API
After=network.target

[Service]
User=ian
WorkingDirectory=/home/ian/geocompare/app
Environment=PYTHONUNBUFFERED=1
Environment=GEOCOMPARE_SQLITE_PATH=/home/ian/geocompare/data/default.sqlite
Environment=GEOCOMPARE_API_HOST=127.0.0.1
Environment=GEOCOMPARE_API_PORT=8000
ExecStart=/home/ian/geocompare/app/.venv/bin/geocompare-api
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
